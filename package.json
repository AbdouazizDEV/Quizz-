{
  "name": "quizzmobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:local": "EXPO_PUBLIC_ENV=local expo start",
    "start:staging": "EXPO_PUBLIC_ENV=staging expo start",
    "start:production": "EXPO_PUBLIC_ENV=production expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "api:dev": "npm run dev --prefix server",
    "eas:android:apk": "eas build -p android --profile preview",
    "eas:android:aab": "eas build -p android --profile production"
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/react-query": "^5.99.0",
    "axios": "^1.15.0",
    "babel-preset-expo": "~54.0.10",
    "clsx": "^2.1.1",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "libphonenumber-js": "^1.12.41",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "rn-international-phone-number": "^0.13.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "eas-cli": "^16.28.0",
    "@types/react": "~19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2"
  },
  "private": true
}
