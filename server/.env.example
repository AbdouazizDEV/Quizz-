PORT=3000

# Deep link utilisé par la page GET / (pont e-mail → app). Doit correspondre au schéma Expo `quizzplus`.
AUTH_DEEP_LINK_TARGET=quizzplus://auth/callback

# Dashboard Supabase → Project Settings → API (même URL que sur la page Data API)
# Ce fichier est chargé APRÈS `.env.local` : si tu définis SUPABASE_URL ici, elle gagne sur EXPO_PUBLIC_SUPABASE_URL.
SUPABASE_URL=https://VOTRE_REF.supabase.co
# Optionnel : timeout fetch vers Supabase (ms). Défaut 30000 (évite le « Connect Timeout 10000ms » d’Undici).
# SUPABASE_FETCH_TIMEOUT_MS=30000
SUPABASE_ANON_KEY=
# Optionnel en local si vous ne testez que register / login / logout / me / Google.
# Obligatoire pour forgot-password, verify-otp, reset-password (et en production).
SUPABASE_SERVICE_ROLE_KEY=

# OTP mot de passe oublié (hash SHA-256 : pepper + code)
# En dev, des valeurs par défaut sont injectées si absentes (ne pas s’en servir en production).
OTP_PEPPER=changez-moi-long-secret-aleatoire

# Jeton opaque signé après verify-otp (HMAC)
RESET_TOKEN_SECRET=autre-secret-long-aleatoire

# URL exacte côté Supabase Auth → Redirect URLs (Google). Si omis : http://localhost:${PORT}/api/v1/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:3000/api/v1/auth/google/callback

# Optionnel : origines CORS séparées par des virgules (défaut * en dev)
# CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# En dev, inclure le code OTP dans la réponse JSON (désactiver en production)
INCLUDE_OTP_IN_RESPONSE=false
